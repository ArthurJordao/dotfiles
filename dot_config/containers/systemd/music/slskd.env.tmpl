{{ $fields := (bitwardenFields "item" "mars-secrets") -}}
# Soulseek (rede)
# NOTE: values are intentionally unquoted. Podman's --env-file (used by quadlets)
# does NOT strip surrounding quotes, so `| quote` would embed literal quotes in
# the value. Passwords must not contain a literal `#` or leading/trailing spaces.
SLSKD_SLSK_USERNAME={{ $fields.SLSKD_SLSK_USERNAME.value }}
SLSKD_SLSK_PASSWORD={{ $fields.SLSKD_SLSK_PASSWORD.value }}

# slskd web UI
SLSKD_USERNAME={{ $fields.SLSKD_WEB_USERNAME.value }}
SLSKD_PASSWORD={{ $fields.SLSKD_WEB_PASSWORD.value }}

# API key for SoulSync (must be >= 16 chars)
SLSKD_API_KEY={{ $fields.SLSKD_API_KEY.value }}
