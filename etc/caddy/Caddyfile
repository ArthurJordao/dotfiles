# Reverse-proxy upstreams use 127.0.0.1, never localhost. localhost resolves to
# ::1 (IPv6) first, and rootless podman containers on the default network use
# pasta, which only forwards IPv4 — an IPv6 connection is accepted then dropped,
# which Caddy surfaces as a 502 (it won't fall back once the socket connects).
# 127.0.0.1 is unambiguous and works regardless of the container's net backend.

immich.arthurjordao.dev {
    reverse_proxy 127.0.0.1:2283

    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
    log {
        output file /var/log/caddy/immich-access.log
        format json
    }
}

dns.arthurjordao.dev {
    reverse_proxy https://127.0.0.1:8053 {
        transport http {
            tls_insecure_skip_verify
        }
    }
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
}

